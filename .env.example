# Local development env (copy to .env and fill in).

# Default Search Console property used when a tool call omits siteUrl.
# Examples:
#   sc-domain:jollyroom.se
#   https://www.jollyroom.se/
GSC_DEFAULT_SITE=

# Path to a service account JSON keyfile (preferred for local dev).
GOOGLE_APPLICATION_CREDENTIALS=

# OR provide the full JSON document inline (preferred for hosted deploys).
GOOGLE_SERVICE_ACCOUNT_JSON=

LOG_LEVEL=info
MCP_MODE=stdio
PORT=3001
