# Personal config for `npm run ship` (Search Console MCP). Copy to `.env.ship` (gitignored).

# SSH command — full invocation, no remote command appended.
# Default is `ssh ga4`; if your shell can't read the alias, use the explicit form below.
# GSC_SSH_CMD=ssh -i /c/Users/<username>/.ssh/id_ed25519_ga4_server -o IdentitiesOnly=yes <user>@<host>

# Repo path on the server. Default: ~/apps/MCP-Search-Console
# GSC_SERVER_PATH=~/apps/MCP-Search-Console

# Health URL polled on the server. Default: http://127.0.0.1:3001/health
# GSC_HEALTH_URL=http://127.0.0.1:3001/health
