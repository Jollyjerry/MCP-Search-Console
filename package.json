{
  "name": "mcp-search-console",
  "version": "0.1.0",
  "description": "MCP server for Google Search Console (queries, clicks, impressions, indexing).",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "build:dxt": "node scripts/buildDxt.mjs",
    "pack:dxt": "node scripts/packDxt.mjs",
    "ship": "node scripts/ship.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.1",
    "googleapis": "^144.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "bestzip": "^2.2.3",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
